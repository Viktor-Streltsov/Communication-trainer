# ── LLM Provider ─────────────────────────────────────────────────────────────
#
# По умолчанию используется Groq:
#   • Бесплатный API, регистрация без привязки карты
#   • Получить ключ: https://console.groq.com → API Keys → Create API Key
#   • Использует формат OpenAI Chat Completions — клиент переписывать не нужно
#
# Чтобы сменить провайдера, измените три переменные ниже:
#
#   Провайдер   | LLM_PROVIDER   | LLM_API_BASE_URL                    | LLM_MODEL
#   ------------|----------------|-------------------------------------|----------------------
#   Groq        | groq           | https://api.groq.com/openai/v1      | llama-3.3-70b-versatile
#   OpenAI      | openai         | https://api.openai.com/v1           | gpt-4o-mini
#   OpenRouter  | openrouter     | https://openrouter.ai/api/v1        | mistralai/mistral-7b-instruct
#
LLM_PROVIDER=groq
LLM_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LLM_MODEL=llama-3.3-70b-versatile
LLM_API_BASE_URL=https://api.groq.com/openai/v1

# ── Database ──────────────────────────────────────────────────────────────────
#
# asyncpg driver is required (included in requirements.txt).
# For local development, use the docker-compose.yml in this directory:
#   docker compose up -d
# Then DATABASE_URL matches the defaults below.
#
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5433/communication_trainer

# ── Server ────────────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000

# CORS: адреса мобильного dev-сервера (Vite / Capacitor live reload)
CORS_ORIGINS=["http://localhost:3000","http://localhost:8100"]

# ── Email (Resend) ────────────────────────────────────────────────────────────
#
# Бесплатный тариф: до 100 писем/день, регистрация без карты.
# Получить ключ: https://resend.com → API Keys → Create API Key
#
# RESEND_FROM_EMAIL — адрес отправителя. На бесплатном тарифе можно
# использовать "onboarding@resend.dev" или собственный верифицированный домен.
#
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@resend.dev

# ── JWT ───────────────────────────────────────────────────────────────────────
#
# Секрет для подписи JWT-токенов. Замените на случайную строку в продакшене:
#   python -c "import secrets; print(secrets.token_hex(32))"
#
JWT_SECRET=change-me-in-production
